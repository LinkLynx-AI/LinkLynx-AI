project_id = "linklynx-prod"
region     = "us-east1"
artifact_registry_repository_id = "application-images"

# Optional: set when using service account impersonation.
terraform_admin_service_account_email = "terraform-admin@linklynx-bootstrap.iam.gserviceaccount.com"
enable_minimal_gke_cluster            = true
enable_rust_api_smoke_deploy          = false
enable_minimal_cloud_sql_baseline     = false
enable_minimal_monitoring_baseline    = false
enable_minimal_security_baseline      = false
enable_minimal_dragonfly_baseline     = false
enable_minimal_scylla_runtime_baseline = false
enable_minimal_managed_messaging_secret_baseline = false
enable_minimal_search_secret_baseline = false
enable_standard_gke_cluster_baseline   = false
enable_standard_workload_identity_baseline = false
enable_standard_gitops_baseline        = false
enable_standard_cloud_sql_baseline     = false
standard_cloud_sql_tier                = "db-custom-4-16384"
standard_cloud_sql_database_name       = "linklynx"
standard_cloud_sql_prod_ha_enabled     = true
standard_cloud_sql_prod_read_replica_enabled = false
rust_api_image_digest                 = "us-east1-docker.pkg.dev/linklynx-prod/application-images/rust@sha256:0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"
rust_api_public_hostname              = "api.example.com"
minimal_dragonfly_image               = "docker.dragonflydb.io/dragonflydb/dragonfly:vX.Y.Z"
minimal_scylla_hosts                  = ["10.80.0.10:9042"]
minimal_scylla_keyspace               = "chat"
minimal_scylla_schema_path            = "/app/database/scylla/001_lin139_messages.cql"
minimal_scylla_request_timeout_ms     = 1000
minimal_redpanda_secret_ids           = ["linklynx-prod-redpanda-bootstrap-servers", "linklynx-prod-redpanda-sasl-username", "linklynx-prod-redpanda-sasl-password"]
minimal_nats_secret_ids               = ["linklynx-prod-nats-url", "linklynx-prod-nats-creds"]
minimal_search_secret_ids             = ["linklynx-prod-search-elastic-api-key", "linklynx-prod-search-elastic-cloud-id", "linklynx-prod-search-elastic-endpoint"]
minimal_cloud_sql_tier                = "db-g1-small"
minimal_cloud_sql_database_name       = "linklynx"
minimal_monitoring_alert_email_addresses = [
  "ops@example.com",
]
standard_gitops_repository_url         = "https://github.com/LinkLynx-AI/LinkLynx-AI.git"
standard_gitops_target_revision        = "main"

# Fill these with the real production domain before plan/apply.
public_dns_zone_name = "linklynx-prod-public"
public_dns_name      = "example.com."
public_hostnames = [
  "api.example.com.",
]
