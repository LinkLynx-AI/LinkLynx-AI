project_id = "linklynx-staging"
region     = "us-east1"
artifact_registry_repository_id = "application-images"

# Optional: set when using service account impersonation.
terraform_admin_service_account_email = "terraform-admin@linklynx-bootstrap.iam.gserviceaccount.com"

# Fill these with the real staging domain before plan/apply.
public_dns_zone_name = "linklynx-staging-public"
public_dns_name      = "staging.example.com."
public_hostnames = [
  "api.staging.example.com.",
]

enable_standard_gke_cluster_baseline   = true
enable_standard_workload_identity_baseline = true
enable_standard_gitops_baseline        = true
standard_gitops_repository_url         = "https://github.com/LinkLynx-AI/LinkLynx-AI.git"
standard_gitops_target_revision        = "main"
