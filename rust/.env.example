# Rust API デプロイ用環境変数
#
# 必須:
# - FIREBASE_PROJECT_ID
# - DATABASE_URL
# - AUTH_ALLOW_POSTGRES_NOTLS
#
# 起動時fail-fast契約:
# - 必須項目が欠落している場合は起動時エラーになります。
# - 任意項目でも、設定した値が不正な場合は起動時エラーになります。
#
# 注意:
# - 現行実装では principal_id 解決の Postgres 接続で TLS コネクタ未実装のため、
#   ローカル環境では AUTH_ALLOW_POSTGRES_NOTLS=true が必要です。

# Firebase プロジェクトID（必須）
FIREBASE_PROJECT_ID=your-firebase-project-id

# Postgres 接続文字列（必須）
DATABASE_URL=postgres://postgres:password@localhost:5432/linklynx

# Postgres 非TLS接続を許可（必須）
AUTH_ALLOW_POSTGRES_NOTLS=true

# --- ここから下は未設定時にデフォルトが使われる任意項目 ---

# Firebase Audience（未設定時: FIREBASE_PROJECT_ID）
FIREBASE_AUDIENCE=your-firebase-project-id

# Firebase Issuer（未設定時: https://securetoken.google.com/<project_id>）
FIREBASE_ISSUER=https://securetoken.google.com/your-firebase-project-id

# Firebase JWKS URL（未設定時はGoogle既定URL）
FIREBASE_JWKS_URL=https://www.googleapis.com/service_accounts/v1/jwk/securetoken@system.gserviceaccount.com

# JWKS キャッシュTTL秒（既定: 300）
FIREBASE_JWKS_TTL_SECONDS=300

# JWKS 取得タイムアウト秒（既定: 5）
FIREBASE_HTTP_TIMEOUT_SECONDS=5

# iat 許容スキュー秒（既定: 60）
FIREBASE_IAT_SKEW_SECONDS=60

# principal キャッシュTTL秒（既定: 300）
AUTH_PRINCIPAL_CACHE_TTL_SECONDS=300

# principal store 接続プール数（既定: 4）
AUTH_PRINCIPAL_STORE_POOL_SIZE=4

# principal store リトライ回数（既定: 2）
AUTH_PRINCIPAL_STORE_MAX_RETRIES=2

# principal store リトライ初期待機ms（既定: 25）
AUTH_PRINCIPAL_STORE_RETRY_BASE_BACKOFF_MS=25

# WS 再認証猶予秒（既定: 30）
WS_REAUTH_GRACE_SECONDS=30

# WS ticket TTL秒（既定: 60）
WS_TICKET_TTL_SECONDS=60

# WS identify待機タイムアウト秒（既定: 5）
AUTH_IDENTIFY_TIMEOUT_SECONDS=5

# WS ticket発行レート制限（1分あたり/主体単位、既定: 20）
WS_TICKET_RATE_LIMIT_MAX_PER_MINUTE=20

# WS identify試行レート制限（1分あたり/Origin単位、既定: 60）
WS_IDENTIFY_RATE_LIMIT_MAX_PER_MINUTE=60

# 許可するWS Origin（カンマ区切り、既定: localhost系）
WS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ログレベル（既定相当: info）
RUST_LOG=info
