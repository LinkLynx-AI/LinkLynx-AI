# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=linklynx

# Rust Backend
DATABASE_URL=postgres://postgres:password@localhost:5432/linklynx
RUST_LOG=info
SERVER_PORT=8080

# TypeScript / Prisma
# Prisma also uses DATABASE_URL (same Postgres connection).

# Next.js Frontend
NEXT_PUBLIC_API_URL=http://localhost:8080

# ScyllaDB
SCYLLA_HOSTS=localhost:9042
