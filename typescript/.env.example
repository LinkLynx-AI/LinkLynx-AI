# TypeScript (Next.js) デプロイ用環境変数
#
# 必須:
# - NEXT_PUBLIC_API_URL
#
# 備考:
# - PORT / HOSTNAME はコンテナ実行時に基盤側で注入されることが多いですが、
#   ローカル確認や明示運用のためにここにも記載しています。

# フロントエンドが参照する API ベースURL（必須）
NEXT_PUBLIC_API_URL=http://localhost:8080

# Next.js 実行ポート（任意、既定はコンテナ側設定）
PORT=3000

# Next.js バインド先ホスト（任意）
HOSTNAME=0.0.0.0

# 実行環境（任意）
NODE_ENV=production

# Prisma を使う場合の接続文字列（任意）
DATABASE_URL=postgres://postgres:password@localhost:5432/linklynx
