generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// This model contains an expression index which requires additional setup for migrations. Visit https://pris.ly/d/expression-indexes for more info.
model User {
  id                                 BigInt                     @id
  email                              String
  emailVerified                      Boolean                    @default(false) @map("email_verified")
  passwordHash                       String                     @map("password_hash")
  displayName                        String                     @map("display_name")
  avatarKey                          String?                    @map("avatar_key")
  statusText                         String?                    @map("status_text")
  birthDate                          DateTime?                  @map("birth_date") @db.Date
  theme                              String                     @default("dark")
  createdAt                          DateTime                   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                          DateTime                   @default(now()) @map("updated_at") @db.Timestamptz(6)
  audit_logs                         audit_logs[]
  channel_reads                      channel_reads[]
  channels                           channels[]
  dm_pairs_dm_pairs_user_highTousers dm_pairs[]                 @relation("dm_pairs_user_highTousers")
  dm_pairs_dm_pairs_user_lowTousers  dm_pairs[]                 @relation("dm_pairs_user_lowTousers")
  dm_participants                    dm_participants[]
  email_verification_tokens          email_verification_tokens?
  guild_members                      guild_members[]
  guilds                             guilds[]
  invite_uses                        invite_uses[]
  invites                            invites[]
  password_reset_tokens              password_reset_tokens?

  @@map("users")
}

model audit_logs {
  id          BigInt       @id
  guild_id    BigInt?
  actor_id    BigInt?
  action      audit_action
  target_type String?
  target_id   BigInt?
  metadata    Json         @default("{}")
  created_at  DateTime     @default(now()) @db.Timestamptz(6)
  users       User?        @relation(fields: [actor_id], references: [id], onUpdate: NoAction)
  guilds      guilds?      @relation(fields: [guild_id], references: [id], onUpdate: NoAction)
}

model channel_last_message {
  channel_id      BigInt   @id
  last_message_id BigInt
  last_message_at DateTime @db.Timestamptz(6)
  updated_at      DateTime @default(now()) @db.Timestamptz(6)
  channels        channels @relation(fields: [channel_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([last_message_at(sort: Desc)], map: "idx_channel_last_message_time")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model channel_permission_overrides {
  channel_id BigInt
  level      role_level
  can_view   Boolean?
  can_post   Boolean?
  channels   channels   @relation(fields: [channel_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([channel_id, level])
}

model channel_reads {
  channel_id           BigInt
  user_id              BigInt
  last_read_message_id BigInt?
  last_client_seq      BigInt?
  updated_at           DateTime @default(now()) @db.Timestamptz(6)
  channels             channels @relation(fields: [channel_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users                User     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([channel_id, user_id])
  @@index([user_id], map: "idx_channel_reads_user")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model channels {
  id                           BigInt                         @id
  type                         channel_type
  guild_id                     BigInt?
  name                         String?
  created_by                   BigInt?
  created_at                   DateTime                       @default(now()) @db.Timestamptz(6)
  updated_at                   DateTime                       @default(now()) @db.Timestamptz(6)
  channel_last_message         channel_last_message?
  channel_permission_overrides channel_permission_overrides[]
  channel_reads                channel_reads[]
  users                        User?                          @relation(fields: [created_by], references: [id], onUpdate: NoAction)
  guilds                       guilds?                        @relation(fields: [guild_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  dm_pairs                     dm_pairs?
  dm_participants              dm_participants[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model dm_pairs {
  user_low                        BigInt
  user_high                       BigInt
  channel_id                      BigInt   @unique(map: "uq_dm_pairs_channel")
  channels                        channels @relation(fields: [channel_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users_dm_pairs_user_highTousers User     @relation("dm_pairs_user_highTousers", fields: [user_high], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users_dm_pairs_user_lowTousers  User     @relation("dm_pairs_user_lowTousers", fields: [user_low], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([user_low, user_high])
}

model dm_participants {
  channel_id BigInt
  user_id    BigInt
  channels   channels @relation(fields: [channel_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users      User     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([channel_id, user_id])
  @@index([user_id], map: "idx_dm_participants_user")
}

model email_verification_tokens {
  user_id    BigInt   @id
  token_hash String   @unique
  expires_at DateTime @db.Timestamptz(6)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  users      User     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([expires_at], map: "idx_email_verification_expires")
}

model guild_member_roles {
  guild_id      BigInt
  user_id       BigInt
  level         role_level
  guild_roles   guild_roles   @relation(fields: [guild_id, level], references: [guild_id, level], onUpdate: NoAction)
  guild_members guild_members @relation(fields: [guild_id, user_id], references: [guild_id, user_id], onDelete: Cascade, onUpdate: NoAction)

  @@id([guild_id, user_id])
}

model guild_members {
  guild_id           BigInt
  user_id            BigInt
  joined_at          DateTime            @default(now()) @db.Timestamptz(6)
  nickname           String?
  guild_member_roles guild_member_roles?
  guilds             guilds              @relation(fields: [guild_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users              User                @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([guild_id, user_id])
  @@index([user_id], map: "idx_guild_members_user")
}

model guild_roles {
  guild_id           BigInt
  level              role_level
  name               String
  guild_member_roles guild_member_roles[]
  guilds             guilds               @relation(fields: [guild_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([guild_id, level])
}

model guilds {
  id            BigInt          @id
  name          String
  owner_id      BigInt
  icon_key      String?
  created_at    DateTime        @default(now()) @db.Timestamptz(6)
  updated_at    DateTime        @default(now()) @db.Timestamptz(6)
  audit_logs    audit_logs[]
  channels      channels[]
  guild_members guild_members[]
  guild_roles   guild_roles[]
  users         User            @relation(fields: [owner_id], references: [id], onUpdate: NoAction)
  invites       invites[]
}

model invite_uses {
  invite_id BigInt
  used_by   BigInt
  used_at   DateTime @default(now()) @db.Timestamptz(6)
  invites   invites  @relation(fields: [invite_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users     User     @relation(fields: [used_by], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([invite_id, used_by])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model invites {
  id          BigInt        @id
  guild_id    BigInt
  created_by  BigInt?
  code        String        @unique
  expires_at  DateTime?     @db.Timestamptz(6)
  max_uses    Int?
  uses        Int           @default(0)
  is_disabled Boolean       @default(false)
  created_at  DateTime      @default(now()) @db.Timestamptz(6)
  invite_uses invite_uses[]
  users       User?         @relation(fields: [created_by], references: [id], onUpdate: NoAction)
  guilds      guilds        @relation(fields: [guild_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([guild_id], map: "idx_invites_guild")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model outbox_events {
  id            BigInt        @id
  event_type    String
  aggregate_id  String
  payload       Json
  status        outbox_status @default(PENDING)
  attempts      Int           @default(0)
  next_retry_at DateTime?     @db.Timestamptz(6)
  created_at    DateTime      @default(now()) @db.Timestamptz(6)
  updated_at    DateTime      @default(now()) @db.Timestamptz(6)

  @@index([status, next_retry_at, created_at], map: "idx_outbox_pending")
}

model password_reset_tokens {
  user_id    BigInt   @id
  token_hash String   @unique
  expires_at DateTime @db.Timestamptz(6)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  users      User     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([expires_at], map: "idx_password_reset_expires")
}

enum audit_action {
  INVITE_CREATE
  INVITE_DISABLE
  GUILD_MEMBER_JOIN
  GUILD_MEMBER_LEAVE
  ROLE_ASSIGN
  ROLE_REVOKE
  CHANNEL_CREATE
  CHANNEL_UPDATE
  CHANNEL_DELETE
  MESSAGE_DELETE_MOD
  USER_BAN
  USER_UNBAN
}

enum channel_type {
  guild_text
  dm
}

enum outbox_status {
  PENDING
  SENT
  FAILED
}

enum role_level {
  owner
  admin
  member
}
